# Meta WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_FLOW_LOGIN_ID=
WHATSAPP_FLOW_SIGNUP_ID=

PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=

# ─── Supabase (Auth + Database) ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI Assistant ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
FEATURE_AI_ASSISTANT=true
FEATURE_NATURAL_LANGUAGE=true

# ─── Payments ───
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=

# ─── Bills & Airtime ───
# Provider: autosyncng | vtpass | clubkonnect
BILLS_PROVIDER=clubkonnect

# ClubKonnect — airtime, data, electricity, cable, betting (docs: https://www.clubkonnect.com/apidocs.asp)
# User ID = your ClubKonnect login username (Developer API page on dashboard)
CLUBKONNECT_USER_ID=
CLUBKONNECT_API_KEY=
CLUBKONNECT_BASE_URL=https://www.nellobytesystems.com

# AutoSyncNG — airtime, data, electricity, cable (docs: https://autosyncng.com/user/developer/docs)
AUTOSYNCNG_API_KEY=
AUTOSYNCNG_API_PIN=
AUTOSYNCNG_BASE_URL=https://autosyncng.com/api/v1

# VTPass fallback (optional — only if BILLS_PROVIDER=vtpass or as secondary)
VTPASS_API_KEY=
VTPASS_PUBLIC_KEY=
VTPASS_SECRET_KEY=
VTPASS_SANDBOX=true
AIRTIME_PROVIDER=vtpass

# ─── Banking ───
BANKING_PROVIDER=paystack
MONO_SECRET_KEY=
ANCHOR_API_KEY=

# ─── Delivery ───
DELIVERY_PROVIDER=internal
CHOWDECK_API_KEY=

# ─── Travel ───
TRAVEL_PROVIDER=wakanow
WAKANOW_API_KEY=

# ─── Loans & Mysogi Credit ───
LOANS_PROVIDER=mysogi
FEATURE_CREDIT=false
CREDIT_MIN_SCORE=250
CREDIT_MAX_SINGLE=5000
CREDIT_FEE_PERCENT=5
CREDIT_REPAYMENT_DAYS=7
CREDIT_AUTO_REPAY=true

# ─── Mysogi Platform API ───
MYSOGI_API_BASE_URL=https://api.mysogi.com.ng
MYSOGI_API_KEY=

# ─── Email OTP ───
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Mysogi <noreply@mysogi.com.ng>
OTP_DEV_MODE=true

# ─── Transaction PIN security ───
PIN_REQUIRED=true
PIN_LENGTH=4
PIN_MAX_ATTEMPTS=5
PIN_LOCKOUT_MINUTES=15
WHATSAPP_FLOW_PIN_SET_ID=
WHATSAPP_FLOW_PIN_VERIFY_ID=
